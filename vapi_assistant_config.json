{
  "name": "Elite AI Sales Agent - Jordan",
  "firstMessage": "Hey there! This is Jordan calling from Elite AI — do you have just a quick sec?",
  "model": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "temperature": 0.7,
    "maxTokens": 250,
    "messages": [
      {
        "role": "system",
        "content": "SYSTEM_PROMPT_PLACEHOLDER"
      }
    ]
  },
  "voice": {
    "provider": "openai",
    "voiceId": "alloy"
  },
  "transcriber": {
    "provider": "deepgram",
    "model": "nova-2",
    "language": "en-US"
  },
  "endCallMessage": "Talk soon!",
  "endCallPhrases": [
    "remove me from your list",
    "do not call me again",
    "put me on your do not call list",
    "stop calling me"
  ],
  "voicemailDetection": {
    "provider": "vapi"
  },
  "backgroundSound": "off",
  "backchannelingEnabled": false,
  "backgroundDenoisingEnabled": true,
  "startSpeakingPlan": {
    "waitSeconds": 0.8,
    "smartEndpointingEnabled": true
  },
  "stopSpeakingPlan": {
    "numWords": 2,
    "voiceSeconds": 0.5,
    "backoffSeconds": 2
  },
  "maxDurationSeconds": 600,
  "silenceTimeoutSeconds": 20,
  "serverUrl": "WEBHOOK_URL_PLACEHOLDER/webhook",
  "serverMessages": [
    "end-of-call-report",
    "status-update",
    "hang"
  ],
  "analysisPlan": {
    "summaryPrompt": "Summarize this sales call in 2 sentences. What was the prospect's main objection or interest, and what was the outcome?",
    "structuredDataPrompt": "Extract the call outcome. Return a JSON object with: { outcome: one of [BOOKED_DEMO, CALLBACK, NOT_INTERESTED, DO_NOT_CALL, VOICEMAIL], callbackTime: string or null, demoTime: string or null, prospectEmail: string or null, notes: string }",
    "structuredDataSchema": {
      "type": "object",
      "properties": {
        "outcome": {
          "type": "string",
          "enum": ["BOOKED_DEMO", "CALLBACK", "NOT_INTERESTED", "DO_NOT_CALL", "VOICEMAIL"]
        },
        "callbackTime": { "type": "string" },
        "demoTime": { "type": "string" },
        "prospectEmail": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["outcome"]
    }
  }
}
