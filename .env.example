# ─────────────────────────────────────────────
# Vapi (voice orchestration)  –  free trial credit
# Get from: https://dashboard.vapi.ai → Account → API Keys
# ─────────────────────────────────────────────
VAPI_API_KEY=your_vapi_api_key_here

# Vapi Assistant ID (created automatically by the setup script)
# Leave blank initially; filled after first run of `node src/create_assistant.js`
VAPI_ASSISTANT_ID=

# ─────────────────────────────────────────────
# Twilio (telephony / caller ID)  –  $15.50 free trial
# Get from: https://console.twilio.com
# Note: Twilio trial only calls VERIFIED numbers
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─────────────────────────────────────────────
# Groq  (LLM brain – completely FREE)
# Get from: https://console.groq.com → API Keys
# Model used: llama-3.3-70b-versatile
# ─────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─────────────────────────────────────────────
# ElevenLabs  (TTS voice – 10k chars/month FREE)
# Get from: https://elevenlabs.io → Profile → API Key
# Voice: Rachel (warm US, mid-30s)  Voice ID below
# ─────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─────────────────────────────────────────────
# Webhook (your public URL when using ngrok)
# After running ngrok: ngrok http 3001
# Then set this to: https://xxxx.ngrok-free.app
# ─────────────────────────────────────────────
WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app

# ─────────────────────────────────────────────
# Backend port
# ─────────────────────────────────────────────
PORT=3001
